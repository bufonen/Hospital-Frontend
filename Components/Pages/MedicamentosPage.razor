    private async Task HandleFormSubmit()
    {
        try
        {
            formSubmitting = true;
            errorMessage = string.Empty;

            if (isEditMode && selectedMedicamento != null)
            {
                // Verificar si hubo cambios
                if (!HuboCambios(formModel, originalMedicamento))
                {
                    await MostrarWarning("No se detectaron cambios. Actualiza alg√∫n campo antes de guardar.");
                    return;
                }

                var updateDto = new MedicamentoUpdateDto
                {
                    Nombre = formModel.Nombre,
                    Fabricante = formModel.Fabricante,
                    Presentacion = formModel.Presentacion,
                    Lote = formModel.Lote,
                    FechaVencimiento = formModel.FechaVencimiento,
                    Stock = formModel.Stock,
                    MinimoStock = formModel.MinimoStock,
                    Precio = formModel.Precio,
                    PrincipioActivo = formModel.PrincipioActivo
                };
                // 1Ô∏è‚É£ Validar fecha de vencimiento menor a 30 d√≠as
                if (formModel.FechaVencimiento.HasValue)
                {
                    var diasRestantes = (formModel.FechaVencimiento.Value - DateTime.Today).TotalDays;
                    if (diasRestantes <= 30)
                    {
                        bool continuar = await MostrarConfirmacion(
                            "Fecha de vencimiento pr√≥xima",
                            $"El medicamento vencer√° en {Math.Max(0, (int)diasRestantes)} d√≠as. ¬øDeseas continuar?"
                        );

                        if (!continuar) return;
                    }
                }

                if (formModel.Stock <= formModel.MinimoStock)
                {
                    bool continuar = await MostrarConfirmacion(
                        "Stock bajo",
                        "El stock actual est√° igual o por debajo del m√≠nimo establecido. ¬øDeseas continuar?"
                    );

                    if (!continuar) return;
                }

                // =======================================================================

                await MedicamentoService.UpdateAsync(selectedMedicamento.Id, updateDto);
                await MostrarAlertaExito("Medicamento actualizado exitosamente");
            }
            else
            {
                // CREACI√ìN - Manejo simplificado
                var createDto = new MedicamentoCreateDto
                {
                    Nombre = formModel.Nombre,
                    Fabricante = formModel.Fabricante,
                    Presentacion = formModel.Presentacion,
                    Lote = formModel.Lote,
                    FechaVencimiento = formModel.FechaVencimiento ?? DateTime.Today,
                    Stock = formModel.Stock,
                    MinimoStock = formModel.MinimoStock,
                    Precio = formModel.Precio,
                    PrincipioActivo = formModel.PrincipioActivo
                };
                // ======================= VALIDACIONES ADICIONALES =======================
                // 1Ô∏è‚É£ Validar fecha de vencimiento menor a 30 d√≠as
                if (formModel.FechaVencimiento.HasValue)
                {
                    var diasRestantes = (formModel.FechaVencimiento.Value - DateTime.Today).TotalDays;
                    if (diasRestantes <= 30)
                    {
                        bool continuar = await MostrarConfirmacion(
                            "Fecha de vencimiento pr√≥xima",
                            $"El medicamento vencer√° en {Math.Max(0, (int)diasRestantes)} d√≠as. ¬øDeseas continuar?"
                        );

                        if (!continuar) return;
                    }
                }

                if (formModel.Stock <= formModel.MinimoStock)
                {
                    bool continuar = await MostrarConfirmacion(
                        "Stock bajo",
                        "El stock actual est√° igual o por debajo del m√≠nimo establecido. ¬øDeseas continuar?"
                    );

                    if (!continuar) return;
                }

                // =======================================================================

                await MedicamentoService.CreateAsync(createDto);
                await MostrarAlertaExito("Medicamento creado exitosamente");
                
                CloseFormModal();
                await LoadMedicamentos();
            }
        }
        catch (HttpRequestException ex) when (ex.Message.Contains("Conflict"))
        {
            // Capturar el error de duplicado del backend
            await ManejarErrorDuplicado(ex);
        }
        catch (InvalidOperationException ex)
        {
            await MostrarAlertaError(ex.Message);
        }
        catch (Exception ex)
        {
            await MostrarAlertaError($"Error al guardar medicamento: {ex.Message}");
        }
        finally
        {
            formSubmitting = false;
        }
    }
    
    private bool HuboCambios(MedicamentoFormModel actual, MedicamentoDto? original)
    {
        if (original == null) return true;

        return
            actual.Nombre != original.Nombre ||
            actual.Presentacion != original.Presentacion ||
            actual.Fabricante != original.Fabricante ||
            actual.Lote != original.Lote ||
            actual.FechaVencimiento != original.FechaVencimiento ||
            actual.Stock != original.Stock ||
            actual.MinimoStock != original.MinimoStock ||
            actual.Precio != original.Precio ||
            actual.PrincipioActivo != original.PrincipioActivo;
    }

    private async Task ManejarErrorDuplicado(HttpRequestException ex)
    {
        try
        {
            // Extraer el ID del medicamento existente del mensaje de error
            var errorMessage = ex.Message;
            var existingId = ExtraerIdDelError(errorMessage);
            
            if (!string.IsNullOrEmpty(existingId))
            {
                // Buscar el medicamento duplicado
                var duplicado = await MedicamentoService.GetByIdAsync(existingId);
                
                if (duplicado != null)
                {
                    if (duplicado.Estado?.Equals("INACTIVO", StringComparison.OrdinalIgnoreCase) == true)
                    {
                        var result = await JS.InvokeAsync<JsonElement>("Swal.fire", new
                        {
                            icon = "question",
                            title = "Medicamento inactivo encontrado",
                            text = "Ya existe un medicamento igual pero est√° inactivo. ¬øDesea reactivarlo?",
                            showCancelButton = true,
                            confirmButtonText = "S√≠, reactivar",
                            cancelButtonText = "Cancelar",
                            confirmButtonColor = "#3085d6",
                            cancelButtonColor = "#d33"
                        });

                        // Leer el valor de 'isConfirmed'
                        bool isConfirmed = result.TryGetProperty("isConfirmed", out var confirmedProp) && confirmedProp.GetBoolean();

                        if (isConfirmed)
                        {
                            await ReactivarMedicamento(duplicado.Id);
                            await MostrarAlertaExito("Medicamento reactivado exitosamente");
                            CloseFormModal();
                            await LoadMedicamentos();
                            return;
                        }
                    }
                    else
                    {
                        // Medicamento activo - mostrar error
                        var htmlContent = $@"
                            <div style='text-align: left;'>
                                <p>Ya existe un medicamento con:</p>
                                <ul>
                                    <li><strong>Nombre:</strong> {duplicado.Nombre}</li>
                                    <li><strong>Presentaci√≥n:</strong> {duplicado.Presentacion}</li>
                                    <li><strong>Fabricante:</strong> {duplicado.Fabricante}</li>
                                </ul>
                            </div>";

                        var result = await JS.InvokeAsync<JsonElement>("Swal.fire", new
                        {
                            icon = "error",
                            title = "Medicamento duplicado",
                            html = htmlContent,
                            confirmButtonText = "Ver medicamento existente",
                            showCancelButton = true,
                            cancelButtonText = "Cerrar",
                            confirmButtonColor = "#3085d6",
                            cancelButtonColor = "#d33"
                        });

                        // Leer el valor de 'isConfirmed'
                        bool isConfirmed = result.TryGetProperty("isConfirmed", out var confirmedProp) && confirmedProp.GetBoolean();

                        if (isConfirmed)
                        {
                            OpenEditModal(duplicado);
                        }
                    }
                }
            }
            else
            {
                await MostrarAlertaError("Medicamento duplicado. No se pudo obtener la informaci√≥n del medicamento existente.");
            }
        }
        catch (Exception innerEx)
        {
            await MostrarAlertaError($"Error al manejar medicamento duplicado: {innerEx.Message}");
        }
    }

    private string ExtraerIdDelError(string errorMessage)
    {
        try
        {
            // El mensaje contiene: {"detail":{"error":"Medicamento duplicado","existing_id":"7aa833ed-1b94-4581-83a9-2b7650679e07"}}
            var match = System.Text.RegularExpressions.Regex.Match(
                errorMessage, 
                @"existing_id"":""([a-fA-F0-9\-]+)"""
            );
            
            return match.Success ? match.Groups[1].Value : null;
        }
        catch
        {
            return null;
        }
    }

