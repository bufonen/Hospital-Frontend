    private List<string> sugerencias = new();
    private bool mostrarSugerencias = false;
    private int indiceSeleccionado = -1;
    private CancellationTokenSource cts = new();

    private string textoBusquedaAuto
    {
        get => textoBusqueda;
        set
        {
            if (textoBusqueda == value) return;
            textoBusqueda = value;
            indiceSeleccionado = -1;
            // Llamada no bloqueante desde el setter
            _ = BuscarSugerenciasAsync();
        }
    }

    private async Task BuscarSugerenciasAsync()
    {
        // cancelar b√∫squedas previas
        cts.Cancel();
        cts = new CancellationTokenSource();

        if (string.IsNullOrWhiteSpace(textoBusqueda) || textoBusqueda.Length < 2)
        {
            sugerencias.Clear();
            mostrarSugerencias = false;
            StateHasChanged();
            return;
        }

        try
        {
            await Task.Delay(200, cts.Token);

            var resultado = await MedicamentoService.GetAllAsync(
                nombre: tipoFiltro == "nombre" ? textoBusqueda : null,
                fabricante: tipoFiltro == "fabricante" ? textoBusqueda : null,
                lote: tipoFiltro == "lote" ? textoBusqueda : null,
                estado: filtroEstado == "" ? null : filtroEstado
            );

            sugerencias = resultado
                .Select(m => tipoFiltro switch
                {
                    "nombre" => m.Nombre,
                    "presentacion" => m.Presentacion,
                    "fabricante" => m.Fabricante,
                    "lote" => m.Lote,
                    _ => m.Nombre
                })
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .Distinct()
                .Take(8)
                .ToList();

            mostrarSugerencias = sugerencias.Any();
            StateHasChanged();
        }
        catch (TaskCanceledException) { /* ignorar */ }
        catch (Exception ex)
        {
            await MostrarAlertaError($"Error al cargar sugerencias: {ex.Message}");
        }
    }
    // Cuando el usuario selecciona una sugerencia (clic o TAB)
    private async Task SeleccionarSugerencia(string valor)
    {
        textoBusqueda = valor;
        mostrarSugerencias = false;
        await AplicarFiltros();
    }
    // Detecta teclas: flechas y tabulador
    private async Task DetectarTecla(KeyboardEventArgs e)
    {
        if (!mostrarSugerencias) return;

        if (e.Key == "ArrowDown")
        {
            indiceSeleccionado = (indiceSeleccionado + 1) % sugerencias.Count;
        }
        else if (e.Key == "ArrowUp")
        {
            indiceSeleccionado = (indiceSeleccionado - 1 + sugerencias.Count) % sugerencias.Count;
        }
        else if (e.Key == "Tab" || e.Key == "Enter")
        {
            if (indiceSeleccionado >= 0 && indiceSeleccionado < sugerencias.Count)
            {
                await SeleccionarSugerencia(sugerencias[indiceSeleccionado]);
            }
            mostrarSugerencias = false;
        }
    }

